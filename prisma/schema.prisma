generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MasterProfile {
  id              String      @id @default(cuid())
  titulo          String
  datosPersonales Json
  experiencia     Json
  educacion       Json
  habilidades     Json
  fotoBase64      String?
  creadoEn        DateTime    @default(now())
  actualizadoEn   DateTime    @updatedAt
  cvsAdaptados    AdaptedCV[]

  @@index([creadoEn])
}

model JobOffer {
  id             String      @id @default(cuid())
  empresa        String
  puesto         String
  descripcionRaw String
  creadoEn       DateTime    @default(now())
  cvsAdaptados    AdaptedCV[]

  @@index([empresa, puesto])
}

model AdaptedCV {
  id              String        @id @default(cuid())
  masterProfileId String
  jobOfferId      String
  contenidoJson   Json
  scoreATS        Float         @default(0.0)
  version         Int           @default(1)
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
  masterProfile   MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)
  jobOffer         JobOffer      @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([jobOfferId, version])
  @@index([masterProfileId])
  @@index([jobOfferId])
}

model AIExecution {
  id               String   @id @default(cuid())
  proveedor        String
  modelo           String
  duracionMs       Int
  promptTokens     Int
  completionTokens Int
  estado           String
  error            String?
  creadoEn         DateTime @default(now())

  @@index([proveedor, modelo])
  @@index([creadoEn])
}
