generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PerfilMaestro {
  id              String       @id @default(cuid())
  titulo          String
  contenidoTexto  String
  archivoUrl      String?
  activo          Boolean      @default(false)
  creadoEn        DateTime     @default(now())
  actualizadoEn   DateTime     @updatedAt
  cvsAdaptados    CVAdaptado[]
}

model OfertaEmpleo {
  id              String       @id @default(cuid())
  empresa         String
  puesto          String
  descripcionRaw  String
  palabrasClave   String[]
  creadoEn        DateTime     @default(now())
  cvsAdaptados    CVAdaptado[]
}

model CVAdaptado {
  id                String        @id @default(cuid())
  perfilMaestroId   String
  ofertaEmpleoId    String
  contenidoJson     Json
  pdfUrl            String?
  plantillaId       String        @default("cv-moderno")
  estadoGeneracion  String        @default("pending")
  scoreFit          Float?
  creadoEn          DateTime      @default(now())
  perfilMaestro     PerfilMaestro @relation(fields: [perfilMaestroId], references: [id])
  ofertaEmpleo      OfertaEmpleo  @relation(fields: [ofertaEmpleoId], references: [id])
}
